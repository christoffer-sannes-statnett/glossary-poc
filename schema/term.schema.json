{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/term.schema.json",
  "title": "GlossaryTerm",
  "description": "A single business glossary term.",
  "type": "object",
  "required": ["slug", "en", "no", "nn"],
  "additionalProperties": false,
  "properties": {
    "slug": {
      "type": "string",
      "description": "Primary key — stable identifier in SCREAMING_SNAKE_CASE.",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "en": {
      "type": "string",
      "description": "English label.",
      "minLength": 1
    },
    "no": {
      "type": "string",
      "description": "Norwegian Bokmål label.",
      "minLength": 1
    },
    "nn": {
      "type": "string",
      "description": "Norwegian Nynorsk label.",
      "minLength": 1
    },
    "description_no": {
      "type": "string",
      "description": "(optional) Human-readable definition in Norwegian Bokmål.",
      "minLength": 5
    },
    "description_en": {
      "type": "string",
      "description": "(optional) Human-readable definition in English.",
      "minLength": 5
    },
    "status": {
      "type": "string",
      "description": "(optional) Lifecycle status. Defaults to 'active'; inferred as 'deprecated' if replaces is set.",
      "enum": ["active", "deprecated", "draft"]
    },
    "replaces": {
      "description": "(optional) Slug of the predecessor term if this term supersedes another, otherwise null.",
      "oneOf": [
        { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        { "type": "null" }
      ]
    },
    "parents": {
      "description": "(optional) Slugs of broader/parent terms — used to group this term in the hierarchy view.",
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
